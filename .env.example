# IslaMediQ Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get free at https://aistudio.google.com/)
# This key is ONLY used server-side (Vercel Serverless / Vite dev proxy)
# It is NEVER exposed to the client-side browser bundle
GEMINI_API_KEY=your_gemini_api_key_here
